@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

include("${CMAKE_CURRENT_LIST_DIR}/plexusTargets.cmake")

# Resolves standalone asio for an installed consumer. The exported plexus::plexus_asio_dep
# (shared by the asio and crypto components) links the host-resolved leaf — asio::asio on a
# find_package host, PkgConfig::plexus_asio_pc on a pkg-config host — so that leaf is recreated
# here, mirroring cmake/plexus-deps.cmake's order. plexus::plexus_asio_dep itself is NOT
# recreated (it ships in the export set). A macro, not a function, so the resolved imported
# targets land in the caller's scope.
macro(_plexus_resolve_asio_leaf)
    if(NOT TARGET asio::asio AND NOT TARGET PkgConfig::plexus_asio_pc)
        find_package(asio CONFIG QUIET)
        if(NOT (asio_FOUND AND TARGET asio::asio))
            find_package(PkgConfig QUIET)
            if(PkgConfig_FOUND)
                pkg_check_modules(plexus_asio_pc QUIET IMPORTED_TARGET asio)
            endif()
        endif()
    endif()
endmacro()

# Includes a backend component's targets file when present, running its find_dependency wiring
# first. crypto's targets file references plexus::asio and plexus::plexus_asio_dep, so the asio
# component's targets file is loaded ahead of it. A component with no installed targets file (e.g.
# one that links FetchContent build-tree targets install(EXPORT) cannot carry) reports FOUND FALSE
# without erroring; check_required_components turns a REQUIRED miss into a hard error.
macro(_plexus_load_component comp)
    if(NOT plexus_${comp}_FOUND)
        set(_plexus_comp_file "${CMAKE_CURRENT_LIST_DIR}/plexus-${comp}-targets.cmake")
        if(EXISTS "${_plexus_comp_file}")
            if("${comp}" STREQUAL "asio")
                _plexus_resolve_asio_leaf()
            elseif("${comp}" STREQUAL "crypto")
                _plexus_resolve_asio_leaf()
                find_dependency(OpenSSL)
                _plexus_load_component(asio)
            elseif("${comp}" STREQUAL "asio-shm")
                # The shm-include headers call io_uring_* directly; the exported targets
                # file references PkgConfig::LIBURING (and plexus::asio / plexus::native), so
                # an installed consumer recreates that imported target here.
                _plexus_resolve_asio_leaf()
                _plexus_load_component(asio)
                _plexus_load_component(native)
                find_dependency(PkgConfig)
                pkg_check_modules(LIBURING REQUIRED IMPORTED_TARGET liburing)
            endif()
            include("${_plexus_comp_file}")
            set(plexus_${comp}_FOUND TRUE)
        else()
            set(plexus_${comp}_FOUND FALSE)
        endif()
    endif()
endmacro()

foreach(comp ${plexus_FIND_COMPONENTS})
    _plexus_load_component(${comp})
endforeach()

check_required_components(plexus)
